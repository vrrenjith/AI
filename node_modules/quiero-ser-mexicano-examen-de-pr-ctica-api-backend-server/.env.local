
// Host to listen on for the backend server.
// By Default, listen to only on localhost. This ensures that the backend server
// is only accessible from the local proxy server.
// Change this at your own risk, changing this can allow public access to the
// backend server.
API_BACKEND_HOST = "127.0.0.1"

// Port to listen on for the backend server.
API_BACKEND_PORT = 5000

// Max size of accepted by the backend server.
API_PAYLOAD_MAX_SIZE = "7mb"

//Google Cloud Project Configuration
GOOGLE_CLOUD_LOCATION = "us-central1"
GOOGLE_CLOUD_PROJECT = "project-540bd254-358f-4a23-a58"

// Random proxy header
PROXY_HEADER = "EdjIn5IdNizmiB7H7kjRXDrF-23rueYN"
